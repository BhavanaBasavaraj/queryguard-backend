# Database
DATABASE_URL=postgresql://user:password@localhost:5432/queryguard

# Redis
REDIS_URL=redis://localhost:6379

# LLM API Keys
GEMINI_API_KEY=
NVIDIA_API_KEY=

# JWT Auth
SECRET_KEY=change-me-to-a-random-32-char-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# AWS
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# DynamoDB
DYNAMODB_TABLE=queryguard-audit-logs
# Set this for local DynamoDB emulation; leave empty to use real AWS DynamoDB
DYNAMODB_ENDPOINT_URL=http://localhost:8001

# App
DEBUG=false
MAX_ROWS=10000
QUERY_TIMEOUT=30
RATE_LIMIT_PER_DAY=100
